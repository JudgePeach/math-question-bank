# ==========================================
# 本地数学题库管理系统 - 环境变量配置模版
# 使用方法：复制本文件并重命名为 .env，然后填写对应 API 密钥
# ==========================================

# --- OCR 图像识别引擎偏好配置 ---
# 可选值：
# - ali_bailian (阿里百炼，首选推荐，速度最快且公式识别准确)
# - siliconflow (硅基流动，调用 Qwen 视觉语言模型)
OCR_PREFER_ENGINE=ali_bailian

# 1. 阿里百炼 OCR (阿里云大模型)
# 请在阿里云百炼控制台获取 API Key
ALI_BAILIAN_API_KEY=your_ali_bailian_api_key_here
ALI_BAILIAN_OCR_MODEL=qwen3-vl-flash

# 2. SiliconFlow OCR (硅基流动)
# 请通过专属邀请链接注册并获取 API Key：https://cloud.siliconflow.cn/i/hkgjSWrg
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# 模型可选择：
# - Qwen/Qwen3-VL-8B-Instruct (推荐，正常够用，性价比较高)
# - Qwen/Qwen3-VL-32B-Instruct (双倍价格但效果更好)
SILICONFLOW_OCR_MODEL=Qwen/Qwen3-VL-8B-Instruct

# --- 大模型 AI 推理与解析配置 ---
# DeepSeek API 密钥
# 请在 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# AI 答题与解析模型指定
# 支持配置如 deepseek-chat (DeepSeek V3), deepseek-reasoner (DeepSeek R1), qwen-max 等
PREFER_SOLVE_MODEL=deepseek-chat
PREFER_PARSE_MODEL=deepseek-chat
