# ==========================================
# 本地数学题库管理系统 - Git 忽略配置
# ==========================================

# 1. 忽略本地环境变量文件（内含敏感 API Keys 和 Tokens，绝对不能公开）
.env

# 2. 忽略本地 SQLite 数据库文件、日志文件及临时测试数据库备份
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.*
*.failed_attempt

# 3. 忽略本地备份目录下的所有数据备份
# 但通过排除 .gitkeep，使得 data_backup 目录结构可以被提交到 GitHub 上
data_backup/*
!data_backup/.gitkeep

# 4. 忽略用户上传的插图资源
# 但通过排除 .gitkeep，使得 static/uploads 目录结构可以被提交到 GitHub 上
static/uploads/*
!static/uploads/.gitkeep

# 5. 忽略 Python 运行缓存、测试缓存及本地临时草稿代码目录
.system_generated/
__pycache__/
*.pyc
.pytest_cache/
.pytest/
scratch/

# 6. 忽略操作系统临时文件与 IDE 配置文件
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# 7. 忽略 Python 虚拟环境与本地构建输出目录
dist/
venv/

# 8. 忽略打包构建缓存
.build_cache/
